rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Employee Validation
    function isValidEmployee(data) {
      return data.keys().hasAll(['name', 'idNumber', 'employeeId', 'joinDate', 'jobStatus', 'jobTitle', 'phoneNumber'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 500
        && data.idNumber is string && data.idNumber.size() > 0 && data.idNumber.size() <= 50
        && data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() <= 50
        && data.joinDate is string
        && data.jobStatus is string
        && data.jobTitle in ["حارس امن", "مشرف استقبال", "حارس استقبال", "كنترول", "مشرف", "مشرفة", "حارسة", "منسق", "مشرف عام"]
        && data.phoneNumber is string && data.phoneNumber.size() > 0 && data.phoneNumber.size() <= 20;
    }

    match /employees/{employeeId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(employeeId)
        && isValidEmployee(incoming())
        && incoming().createdAt == request.time;
      allow update: if isSignedIn()
        && isValidEmployee(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn();
    }
  }
}
