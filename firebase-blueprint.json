{
  "entities": {
    "employee": {
      "title": "Employee",
      "description": "Employee record containing personal and job-related information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the employee" },
        "idNumber": { "type": "string", "description": "National ID number" },
        "employeeId": { "type": "string", "description": "Company employee ID" },
        "joinDate": { "type": "string", "format": "date", "description": "Date of joining/hiring" },
        "jobStatus": { "type": "string", "description": "Current employment status" },
        "jobTitle": { 
          "type": "string", 
          "enum": ["حارس امن", "مشرف استقبال", "حارس استقبال", "كنترول", "مشرف", "مشرفة", "حارسة", "منسق", "مشرف عام"],
          "description": "Specific job role"
        },
        "phoneNumber": { "type": "string", "description": "Mobile phone number" },
        "idPhoto": { "type": "string", "description": "Base64 encoded string of the ID photo" },
        "securityFile": { "type": "string", "description": "Base64 encoded string of the security file (image or PDF)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "idNumber", "employeeId", "joinDate", "jobStatus", "jobTitle", "phoneNumber"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "employee",
      "description": "Collection of employee records"
    }
  }
}
